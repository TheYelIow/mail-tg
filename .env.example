# ── Resend ───────────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys (needs full access to send + read received)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Signing secret of the inbound webhook (Resend → Webhooks → your endpoint)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Default "From" address used when replying. Must be on a domain verified in Resend.
# The bot replies from the address the mail was sent TO when possible, falling back to this.
MAIL_FROM="Inbox <inbox@yourdomain.com>"

# ── Telegram ─────────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your personal chat id (the only chat allowed to use the bot).
# Get it from @userinfobot or the /start handler logs.
TELEGRAM_CHAT_ID=123456789
# A random string you invent; set as the secret_token when registering the webhook
# and checked on every incoming Telegram update.
TELEGRAM_WEBHOOK_SECRET=make-up-a-long-random-string

# Public base URL of the deployed app, e.g. https://tg-mail-bot.vercel.app
# Used by the set-webhook script.
PUBLIC_URL=https://your-app.vercel.app

# ── Upstash Redis (Vercel KV / Upstash) ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxx
